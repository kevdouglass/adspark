# AdSpark — Docker environment template.
#
# Copy this file to `.env.docker` (which is gitignored) and fill in
# the values. Compose reads `.env.docker` at container start via the
# `env_file:` directive in docker-compose.yml.
#
#   cp .env.docker.example .env.docker
#
# IMPORTANT: .env.docker MUST NOT be committed. It's already in
# .gitignore and .dockerignore so it won't leak into the image or
# the repo, but verify before pushing to a public registry.
#
# NEXT_PUBLIC_ vars trap: any variable prefixed with NEXT_PUBLIC_ is
# inlined into the client bundle at BUILD time, not read at runtime.
# Setting NEXT_PUBLIC_FOO here has NO effect on the browser bundle.
# If you need to expose a public var to the client, add it to the
# Dockerfile as an ARG and rebuild:
#
#   ARG NEXT_PUBLIC_FOO
#   ENV NEXT_PUBLIC_FOO=${NEXT_PUBLIC_FOO}
#   RUN npm run build
#
# Then: `docker compose build --build-arg NEXT_PUBLIC_FOO=bar`

# ---------------------------------------------------------------------------
# Required
# ---------------------------------------------------------------------------

# OpenAI API key. Needed for both the DALL-E 3 image pipeline and the
# multi-agent brief orchestrator (gpt-4o-mini).
OPENAI_API_KEY=sk-proj-REPLACE_ME

# ---------------------------------------------------------------------------
# Storage mode (choose one)
# ---------------------------------------------------------------------------

# Local mode — creatives and manifests land in the `/app/output`
# volume mount. Served to the browser via /api/files/[...path].
# Default. Good for single-reviewer demos and offline development.
STORAGE_MODE=local

# S3 mode — creatives upload to S3 and are served via pre-signed URLs.
# Uncomment this block and set STORAGE_MODE=s3 to enable.
#
# STORAGE_MODE=s3
# S3_BUCKET=your-bucket-name
# S3_REGION=us-east-1
# AWS_ACCESS_KEY_ID=AKIA...
# AWS_SECRET_ACCESS_KEY=...

# ---------------------------------------------------------------------------
# Optional — only override if you know what you're doing
# ---------------------------------------------------------------------------

# Absolute path where local-mode output is written. Must match the
# volume mount target in docker-compose.yml. The Dockerfile already
# sets this to /app/output — override here only if you change the
# volume target in compose.
# LOCAL_OUTPUT_DIR=/app/output

# URL base prefix for local-mode file serving. Default is /api/files
# and you almost certainly want to leave it alone — changing it means
# the frontend <img src> URLs no longer match the route handler path.
# LOCAL_URL_BASE=/api/files
