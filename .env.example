# ============================================================================
# AdSpark Environment Configuration
# ============================================================================
#
# Copy this file to `.env.local` and fill in real values. `.env.local` is
# gitignored and stays on your machine.
#
# For Vercel deployment, set each variable in the Vercel dashboard:
#   Settings → Environment Variables → (Preview + Production scopes)
#
# Vercel encrypts env vars at rest (AES-256) and only injects them into
# server-side serverless function invocations — they are NEVER bundled into
# the browser build.
# ============================================================================

# ----------------------------------------------------------------------------
# OpenAI (REQUIRED)
# ----------------------------------------------------------------------------
# DALL-E 3 image generation (pipeline) + gpt-4o-mini (multi-agent brief
# orchestrator). Both features fail fast with MISSING_CONFIGURATION if unset.
# Get a key: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# ----------------------------------------------------------------------------
# Storage Mode (REQUIRED for hosted deploy; defaults to "local" for dev)
# ----------------------------------------------------------------------------
# Valid values: "local" or "s3"
#
# - "local" (default): writes creatives to ./output/ on disk. Works on
#   localhost. Does NOT work on Vercel (stateless serverless sandboxes
#   mean files written during one invocation are gone by the next).
#
# - "s3": writes creatives to an AWS S3 bucket via pre-signed URLs.
#   Required for any hosted deploy (Vercel, Fly, Railway, etc.) where
#   the local filesystem is ephemeral.
STORAGE_MODE=local

# ----------------------------------------------------------------------------
# AWS S3 (REQUIRED when STORAGE_MODE=s3)
# ----------------------------------------------------------------------------
# Credentials for an IAM user with scoped access to your bucket. See the
# README "AWS S3 Setup" section for the minimal IAM policy.
#
# The AWS SDK v3 reads these automatically — no code change needed.
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# The bucket that will hold generated creatives. Must be globally unique
# across all AWS accounts. Example: adspark-prod-kevin-2026
# S3_BUCKET=

# AWS region code (e.g., us-east-1, us-west-2, eu-west-1). Defaults to
# us-east-1 if unset.
# S3_REGION=us-east-1
