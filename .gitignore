# Dependencies
node_modules/
.pnp.*

# Build output
dist/
build/
.next/
out/
# TypeScript incremental build cache — regenerated on every `tsc --noEmit`
tsconfig.tsbuildinfo

# Claude Code local state
.claude/scheduled_tasks.lock

# Environment
.env
.env.local
.env.*.local
.env.docker

# AWS local config (cors.json, scratch policies)
.aws/

# Review reports (generated, not committed)
.review-reports/PR-*.html
.review-reports/pr-findings/pr-*.json
.review-reports/agent-metrics.json

# Action tracker (local state, never committed)
ACTION-TRACKER.md

# Assessment emails (contain personal contact info)
knowledge-base/01-assessment/email-*.md
knowledge-base/01-assessment/round1-intel.md
knowledge-base/01-assessment/business-context.html

# Generated output (local dev)
output/

# Text-overlay preview harness output — produced by
# `npx tsx scripts/preview-text-overlay.ts` for visual-verification of
# textOverlay.ts changes. Gitignored because these are dev artifacts;
# the committed authority is the script that regenerates them.
tmp/

# Demo script scratch file (scripts/demo.sh writes response bodies here)
.demo-resp.json

# Python (legacy, kept for safety)
__pycache__/
*.pyc

# OS
.DS_Store
Thumbs.db

# IDE
.idea/
.vscode/
*.swp

# Test coverage
coverage/

# Logs
*.log
npm-debug.log*
